{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "blog",
  "compatibility_date": "2026-05-06",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },

  "send_metrics": false,

  "env": {
    "dev": {
      "workers_dev": true,
    },

    "production": {
      "routes": [
        {
          "pattern": "gustavojusto.com",
          "custom_domain": true
        }
      ]
    }
  }
}