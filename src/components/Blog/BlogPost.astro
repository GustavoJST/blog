---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/Container.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import { readingTime } from "@/lib/utils";
import BackToPrevious from "@/components/BackToPrevious.astro";
import PostNavigation from "@/components/PostNavigation.astro";
import TableOfContents from "@/components/TOC/TableOfContents.astro";
import Giscus from "@/components/Giscus.astro";
import { SITE } from "@/consts";
import { I18N } from "@/consts";
import { getRelativeLocaleUrl } from "astro:i18n";
import { getLangFromPath, useTranslations } from "@/i18n/utils";
import HorizontalRule from "@/components/HorizontalRule.astro";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const lang = getLangFromPath(Astro.url.pathname);
const t = useTranslations(lang);

const posts = (await getCollection("blog"))
  .filter(
    (p) =>
      !p.data.draft &&
      p.data.lang === post.data.lang &&
      post.data.date <= new Date(),
  )
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const postIndex = posts.findIndex((p) => p.data.url === post.data.url);

// Index + 1 is the older post, Index - 1 is the newer post
const nextPost = posts[postIndex + 1];
const prevPost = posts[postIndex - 1];

const { Content, headings, remarkPluginFrontmatter } = await render(post);
const lastModified: Date = new Date(remarkPluginFrontmatter.lastModified);

const dateFormat: Intl.DateTimeFormatOptions = {
  month: "short",
  day: "2-digit",
  year: "numeric",
  hour: "2-digit",
  minute: "2-digit",
  hourCycle: "h23",
  dayPeriod: "long",
  timeZoneName: "short",
  timeZone: I18N.LANGUAGES[lang].timeZone,
};
---

<script>
  /** Attaches links to headings in the document,
   * allowing sharing of sections easily */
  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6"),
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 opacity-75 md:opacity-0 md:group-hover:opacity-75 md:focus:opacity-75 duration-200 ease-in-out transition";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      link.ariaLabel = "link to heading";
      heading.appendChild(link);
    }
  }
  addHeadingLinks();
</script>

<Layout
  title={post.data.title}
  description={post.data.description}
  pagefindIndex={true}
>
  <Container>
    <div class="animate" data-pagefind-ignore>
      <BackToPrevious href={getRelativeLocaleUrl(lang, "blog")}
        >{t("blog.post.back")}</BackToPrevious
      >
    </div>
    <div class="my-10 space-y-1">
      <div data-pagefind-ignore>
        <div class="animate flex items-center gap-1.5">
          <div class="font-base text-sm">
            <FormattedDate date={post.data.date} />
          </div>
          &bull;
          {
            post.body && (
              <div class="font-base text-sm">
                {readingTime(post.body)} {t("readingTime")}
              </div>
            )
          }
        </div>
        {/* Conditionally render based on commit count */}
        {
          SITE.ENABLE_BLOG_LAST_UPDATED &&
            remarkPluginFrontmatter.commitCount > 1 && (
              <div class="animate flex items-center gap-1.5">
                <div class="text-sm">{t("blog.post.updatedAt")}: </div>
                <div class="text-sm">
                  <FormattedDate date={lastModified} dateFormat={dateFormat} />
                </div>
              </div>
            )
        }
      </div>
      <h1
        data-pagefind-meta="title"
        class="animate text-3xl font-semibold break-words text-black dark:text-white"
      >
        {post.data.title}
      </h1>
      {
        post.data.tags && post.data.tags?.length > 0 ? (
          <div class="animate flex gap-2 pt-1">
            {post.data.tags.map((tag) => (
              <a
                href={getRelativeLocaleUrl(lang, `/tags/${tag}`)}
                class="rounded-sm border border-black/15 px-2 py-1 text-sm transition-colors duration-300 ease-in-out hover:bg-black/5 hover:text-black focus-visible:bg-black/5 focus-visible:text-black dark:border-white/20 dark:hover:bg-white/5 dark:hover:text-white dark:focus-visible:bg-white/5 dark:focus-visible:text-white"
              >
                {tag}
              </a>
            ))}
          </div>
        ) : null
      }
    </div>
    <div class="relative w-full">
      <TableOfContents headings={headings} />
      <article class="animate w-full">
        <HorizontalRule />
        <Content />
        <div class="mt-14">
          <PostNavigation prevPost={prevPost} nextPost={nextPost} />
        </div>
        {
          SITE.ENABLE_GISCUS && (
            <div class="mt-24">
              <Giscus />
            </div>
          )
        }
      </article>
    </div>
  </Container>
</Layout>
