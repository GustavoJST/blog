<script>
  function openSearch() {
    const modal = document.querySelector("pagefind-modal");
    if (modal) {
      // @ts-expect-error - custom element with open()
      modal.open();
    }
  }

  function attachListeners() {
    const btn = document.getElementById("magnifying-glass");
    if (btn) {
      btn.removeEventListener("click", openSearch);
      btn.addEventListener("click", openSearch);
    }
  }

  attachListeners();
  document.addEventListener("astro:after-swap", attachListeners);

  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      openSearch();
    }
  });
</script>

