---
import { getLangFromPath } from "@/i18n/utils";

interface Props {
  date: Date;
  dateFormat?: Intl.DateTimeFormatOptions;
}

const {
  date,
  dateFormat = {
    month: "short",
    day: "2-digit",
    year: "numeric",
    timeZone: "utc",
  },
} = Astro.props;
const lang = getLangFromPath(Astro.url.pathname);
---

<time datetime={date.toISOString()}>
  {date.toLocaleDateString(lang, dateFormat)}
</time>
