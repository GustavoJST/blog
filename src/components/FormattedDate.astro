---
import { getLangFromPath } from "@/i18n/utils";
import { I18N } from "../consts";

interface Props {
  date: Date;
  lastUpdatedFormat?: boolean;
}

const { date, lastUpdatedFormat = false } = Astro.props;
const lang = getLangFromPath(Astro.url.pathname);

const time = date.toLocaleDateString(lang, {
  month: "short",
  day: "2-digit",
  year: "numeric",
});

const timeLastUpdatedFormat = date.toLocaleDateString(lang, {
  month: "short",
  day: "2-digit",
  year: "numeric",
  hour: "2-digit",
  minute: "2-digit",
  hourCycle: "h23",
  dayPeriod: "long",
  timeZoneName: "short",
  timeZone: I18N.LANGUAGES[lang].timeZone,
});
---

<time datetime={date.toISOString()}>
  {lastUpdatedFormat ? timeLastUpdatedFormat : time}
</time>
