---
import { getLangFromPath, useTranslations } from "@/i18n/utils";
import { SITE } from "@consts";
import { execSync } from "child_process";
import FormattedDate from "./FormattedDate.astro";
import Link from "./Link.astro";

interface Props {
  mobile?: boolean;
}

const { mobile = false } = Astro.props;
const lang = getLangFromPath(Astro.url.pathname);
const t = useTranslations(lang);

const abbreviatedHash = execSync(`git log -1 --pretty="format:%h"`)
  .toString()
  .trim();
const fullHash = execSync(`git log -1 --pretty="format:%H"`).toString().trim();
const commitDate = execSync(`git log -1 --pretty="format:%cI"`)
  .toString()
  .trim();

const dateFormat: Intl.DateTimeFormatOptions = {
  month: "2-digit",
  day: "2-digit",
  year: "numeric",
  hour: "2-digit",
  minute: "2-digit",
  hourCycle: "h23",
  timeZoneName: "short",
  timeZone: "utc",
};
---

<div class={`font-light opacity-70 ${mobile ? "text-xs" : "text-sm"}`}>
  {t("footer.lastBuild")}: <FormattedDate
    date={new Date(commitDate)}
    dateFormat={dateFormat}
  />(<Link href=`${SITE.FOOTER_LAST_BUILD_COMMIT_URL}/${fullHash}`
    >{abbreviatedHash}</Link
  >)
</div>
