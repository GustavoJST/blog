---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import BackToPrevious from "@components/BackToPrevious.astro";
import { getLangFromPath, useTranslations } from '@/i18n/utils';
import { SITE } from "@consts";
import { getRelativeLocaleUrl } from "astro:i18n";

const lang = getLangFromPath(Astro.url.pathname);
const t = useTranslations(lang);
---

<Layout title="404" description={SITE.DESCRIPTION}>
  <Container>
    <div class="mt-16 grid place-items-center gap-3">
      <h4 class="animate text-2xl font-semibold text-black dark:text-white">
        404: {t('404.title')}
      </h4>
      <span class="animate">
        <BackToPrevious href={getRelativeLocaleUrl(lang)} >{t('404.backToHome')}</BackToPrevious>
      </span>
    </div>
  </Container>
</Layout>
